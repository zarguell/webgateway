# =============================================================================
# WebGateway — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# =============================================================================

# --- API Keys (search & extraction providers) ---

# Jina Reader API key — https://jina.ai/reader
# Free tier provides generous rate limits.
JINA_API_KEY=

# Firecrawl API key — https://www.firecrawl.dev/
# Required for JS-heavy extraction and structured output.
FIRECRAWL_API_KEY=

# Brave Search API key — https://brave.com/search/api/
# Fast, privacy-respecting search API.
BRAVE_API_KEY=

# Tavily Search API key — https://tavily.com/
# Agent-optimised search / RAG API.
TAVILY_API_KEY=

# Zyte API key — https://www.zyte.com/
# Managed anti-bot extraction for hard targets.
ZYTE_API_KEY=

# --- Authentication Keys ---

# Secret for the primary agent API key (id: key_agent1 in config.yaml)
# Generate with: openssl rand -hex 32
AGENT1_KEY=

# Secret for the admin API key (id: key_admin in config.yaml)
# Used for /admin/* endpoints. Generate with: openssl rand -hex 32
ADMIN_KEY=

# Key used to encrypt session/cookie jar files at rest
# Generate with: openssl rand -hex 32
SESSION_ENCRYPTION_KEY=

# Bootstrap admin key — used for first-run setup when no admin keys exist in DB
# Remove after creating your first real admin key via the Admin UI or API.
# Generate with: openssl rand -hex 32
BOOTSTRAP_ADMIN_KEY=

# Secret for signing admin UI session cookies
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# --- Optional: Self-hosted Firecrawl ---
# Only needed if using docker-compose.firecrawl.yml override.
# Protects the Bull queue manager UI at /admin/@/queues.
BULL_AUTH_KEY=

# --- Optional: Gluetun VPN ---
# Uncomment if using the Gluetun sidecar with WireGuard:
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=
# WIREGUARD_DNS=1.1.1.1
